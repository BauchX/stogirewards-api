# YouTube API Configuration
YOUTUBE_API_KEY=your_youtube_api_key_here

# Comma-separated list of YouTube channel IDs
# Find channel ID: Go to channel > About > Share > Copy channel ID
# Example: UCxxxxxxxxxx,UCyyyyyyyyyy
YOUTUBE_CHANNEL_IDS=UC_x5XG1OV2P6uZZ5FSM9Ttw

# Server configuration
PORT=3001

# CORS - comma-separated list of allowed origins (or leave empty for all)
ALLOWED_ORIGINS=http://localhost:5173,https://stogirewards.com

# Max results per channel (default: 10)
MAX_RESULTS_PER_CHANNEL=10
